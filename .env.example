# Скопируй этот файл в secrets/.env и заполни.
# secrets/ в .gitignore — реальные значения в git НЕ попадают.

# --- Telethon (user-сессия, обязательно) ---
# Получить на https://my.telegram.org → API development tools → создать app
TGCOCKPIT_API_ID=123456
TGCOCKPIT_API_HASH=0123456789abcdef0123456789abcdef

# Имя аккаунта = имя файла сессии в secrets/sessions/<account>.session
TGCOCKPIT_ACCOUNT=main

# --- Опциональный бот (aiogram), для Phase 5+ ---
# Получить у @BotFather → /newbot
TGCOCKPIT_BOT_TOKEN=

# Владелец определяется АВТОМАТИЧЕСКИ из user-сессии (твой аккаунт за API_ID/API_HASH).
# Это поле — только чтобы ДОПОЛНИТЕЛЬНО пустить других людей (их Telegram id через запятую).
# Обычно оставляй пустым.
TGCOCKPIT_OWNER_IDS=

# --- Мост к Claude (headless) ---
# Ключ Anthropic (или оставь пустым — будет использован логин Claude Code)
TGCOCKPIT_ANTHROPIC_API_KEY=
# Модель для моста (пусто = модель по умолчанию Claude Code), напр. claude-opus-4-8
TGCOCKPIT_MODEL=
# Reasoning effort: low | medium | high | xhigh | max (пусто = по умолчанию)
TGCOCKPIT_EFFORT=
